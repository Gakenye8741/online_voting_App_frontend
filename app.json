{
  "expo": {
    "name": "Laikipia Students Vote",
    "slug": "LaikipiaE-Vote",
    "owner": "gakenye123",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Laikipia-logo.png",
    "scheme": "laikipiaevote",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gakenye.laikipiaevote"
    },
    "android": {
      "package": "com.gakenye.laikipiaevote",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/Laikipia-logo.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": false,
      "StatusBar": {
        "barStyle": "dark-content",
        "backgroundColor": "#FFFFFF",
        "translucent": false
      },
      "permissions": [
        "NOTIFICATIONS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/Laikipia-logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Laikipia-logo.png",
          "imageWidth": 250,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-build-properties",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/Laikipia-logo.png",
          "color": "#c8102e"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d229e75d-2668-44c7-bf3c-47be8a1f1a18"
      }
    }
  }
}